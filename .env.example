APP_NAME=Aura Hub API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8002
LOG_LEVEL=INFO

DATABASE_URL=sqlite+aiosqlite:///./data/aura_hub.db

QDRANT_URL=http://qdrant:6335
QDRANT_API_KEY=
QDRANT_COLLECTION=aura_hub_sop_chunks

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=64

LLM_ENABLED=true
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=60
LLM_TEMPERATURE=0.1

MAX_DOCUMENT_SIZE_MB=10
MAX_CSV_SIZE_MB=5
CHUNK_TARGET_TOKENS=420
CHUNK_MAX_TOKENS=520
CHUNK_OVERLAP_TOKENS=60
RAG_DENSE_CANDIDATES=12
RAG_TOP_K=3
RAG_MIN_FINAL_SCORE=0.35

ANOMALY_MODIFIED_Z_THRESHOLD=3.5
ANOMALY_IQR_MULTIPLIER=1.5
ANOMALY_MIN_ROWS=5
